; Engine configuration file.
; Godot 4.x project scaffold for Children of Ikphelion runtime host migration.

config_version=5

[application]
config/name="Children of Ikphelion - Game Client"
run/main_scene="res://scenes/bootstrap.tscn"
config/icon="res://assets/game_icon.png"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4

[rendering]
renderer/rendering_method="gl_compatibility"
